# =========================

# GOOGLE GEMINI

# =========================

GEMINI_API_KEY=your_gemini_api_key

# =========================

# POSTGRESQL (Supabase)

# =========================

POSTGRES_HOST=your-supabase-host.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_supabase_password

# =========================

# FASTAPI BACKEND

# =========================

N8N_WEBHOOK=https://your-n8n-domain.com/webhook/evidence-check-submit
N8N_JOBS_URL=https://your-n8n-domain.com/webhook/evidence-check-jobs
N8N_RESULT_URL=https://your-n8n-domain.com/webhook/evidence-check-result

# =========================

# N8N

# =========================

EVIDENCECHECK_PIPELINE_URL=https://your-domain.com/webhook/evidence-check-v2-webhook

# =========================

# REACT DASHBOARD

# =========================

VITE_EVIDENCECHECK_API_BASE=http://localhost:8000
VITE_EVIDENCECHECK_LIST_JOBS_PATH=/jobs
VITE_EVIDENCECHECK_SUBMIT_JOB_PATH=/analysis
VITE_EVIDENCECHECK_RESULT_JOB_PATH=/result

# =========================

# Optional WhatsApp notification recipient
# Used only if WhatsApp notifications are enabled in n8n

DEFAULT_WHATSAPP_TO=your_phone_number
